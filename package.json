{
	"name": "wikiparser-node",
	"version": "1.44.0",
	"description": "A Node.js parser for MediaWiki markup with AST",
	"keywords": [
		"mediawiki",
		"wikitext",
		"parser",
		"browser"
	],
	"homepage": "https://github.com/bhsd-harry/wikiparser-node#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/wikiparser-node/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"/bundle/bundle*.js",
		"/extensions/dist/*.js",
		"/extensions/*.css",
		"!/extensions/dist/*-page*.js",
		"!/extensions/*-page.css",
		"/printed/README",
		"/errors/README",
		"/config/",
		"!/config/mediawikiwiki.json",
		"!/config/github.json",
		"/data/",
		"/i18n/",
		"/coverage/badge.svg",
		"/bin/*.js",
		"/dist/",
		"!/dist/script/",
		"!/dist/test/"
	],
	"bin": {
		"getParserConfig": "bin/config.js"
	},
	"browser": "/bundle/bundle-lsp.min.js",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/wikiparser-node.git"
	},
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev",
		"prepublishOnly": "npm run build:core",
		"build:core": "bash build.sh",
		"build:define": "bash sed.sh -i \"s/pkg = \\$PKG/pkg = $(npm pkg get name)/; s/version = \\$VERSION/version = $(npm pkg get version)/\" dist/bin/config.js",
		"build": "npm run build:core && LC_ALL=en.UTF-8 node dist/script/parserTests.js",
		"diff": "bash diff.sh",
		"diff:stat": "f() { git diff --stat -w --color=always $1 $2 -- . | grep '\\.ts'; }; f",
		"lint:ts": "tsc --noEmit && eslint --cache .",
		"lint:json": "v8r -s config/.schema.json config/*.json && v8r -s data/.schema.json data/*.json && mocha dist/test/json.js",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:json && npm run lint:md",
		"prof": "node dist/test/prof.js",
		"coverage": "tsc --declaration false --target es2024 && npm run build:define && c8 npm run test:ci && node dist/script/coverage.js && open coverage/index.html",
		"test:unit": "mocha dist/test/test.js",
		"test:math": "mocha dist/test/math.js",
		"test:clonenode": "CLONENODE=1 mocha --require dist/test/env.js dist/test/test.js",
		"test:parser": "LC_ALL=en.UTF-8 mocha dist/test/parserTests.js",
		"test:perf": "mocha --reporter spec dist/test/perf.js",
		"test": "npm run test:unit && npm run test:clonenode && npm run test:parser",
		"test:parseronly": "LSP=0 npm run test:parser",
		"test:ci": "LSP=0 npm test",
		"test:end": "pkill -x http-server",
		"test:real": "node dist/test/real.js"
	},
	"c8": {
		"exclude": [
			"dist/bin/*.js",
			"dist/script/*.js",
			"dist/test/*.js"
		],
		"reporter": [
			"html",
			"text-summary",
			"json-summary"
		]
	},
	"peerDependencies": {
		"ajv": ">=8.0.0",
		"ajv-errors": ">=3.0.0",
		"katex": ">=0.14.0",
		"mathoid-texvcjs": ">=0.4.0",
		"prism-wiki": ">=1.0.0",
		"prismjs": "^1.0.0",
		"stylelint": ">=16.0.0",
		"vscode-css-languageservice": ">=3.0.0",
		"vscode-html-languageservice": ">=3.1.0",
		"vscode-json-languageservice": ">=3.2.0"
	},
	"peerDependenciesMeta": {
		"ajv": {
			"optional": true
		},
		"ajv-errors": {
			"optional": true
		},
		"katex": {
			"optional": true
		},
		"mathoid-texvcjs": {
			"optional": true
		},
		"prism-wiki": {
			"optional": true
		},
		"prismjs": {
			"optional": true
		},
		"stylelint": {
			"optional": true
		},
		"vscode-css-languageservice": {
			"optional": true
		},
		"vscode-html-languageservice": {
			"optional": true
		},
		"vscode-json-languageservice": {
			"optional": true
		}
	},
	"dependencies": {
		"@bhsd/cm-util": "^2.2.0",
		"@bhsd/common": "^3.0.0",
		"@bhsd/nodejs": "^1.1.0",
		"@bhsd/stylelint-util": "^1.1.0",
		"entities": "^8.0.0",
		"vscode-languageserver-types": "^3.18.0"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^3.1.0",
		"@bhsd/test-util": "^2.0.0",
		"@codemirror/lint": "^6.9.7",
		"@eslint/markdown": "^8.0.3",
		"@types/jsdom": "^28.0.3",
		"@types/prismjs": "^1.26.6",
		"ajv": "^8.20.0",
		"ajv-errors": "^3.0.0",
		"c8": "^11.0.0",
		"codejar-async": "^4.3.1",
		"diff2html-cli": "^5.2.15",
		"dompurify": "^3.4.11",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"jsdom": "^29.1.1",
		"katex": "^0.17.0",
		"markdownlint-cli2": "^0.23.0",
		"mathoid-texvcjs": "^0.6.0",
		"mocha": "^11.7.6",
		"monaco-editor": "~0.53.0",
		"prism-wiki": "^2.2.1",
		"prismjs": "^1.30.0",
		"stylelint": "^17.14.0",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"v8r": "^6.1.0",
		"vscode-css-languageservice": "^6.3.10",
		"vscode-html-languageservice": "^5.6.2",
		"vscode-json-languageservice": "^5.7.2",
		"vscode-languageserver-textdocument": "^1.0.12"
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0 || >=24.11.0"
	}
}
