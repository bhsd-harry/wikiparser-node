{
	"name": "wikiparser-template",
	"version": "1.39.1",
	"description": "A light-weight template parser for MediaWiki markup",
	"keywords": [
		"mediawiki",
		"wikitext",
		"parser",
		"browser"
	],
	"homepage": "https://github.com/bhsd-harry/wikiparser-node/tree/template#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/wikiparser-node/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"/bundle/bundle.min.js",
		"/dist/**/*.d.ts",
		"!/dist/test/"
	],
	"main": "./bundle/bundle.min.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/wikiparser-node.git"
	},
	"scripts": {
		"prepublishOnly": "npm run build:core",
		"build:core": "bash build.sh",
		"build:test": "tsc --project tsconfig.dist.json",
		"build": "npm run build:core && npm run build:test",
		"diff": "bash diff.sh",
		"diff:stat": "f() { git diff --stat -w --color=always $1 $2 -- . | grep '\\.ts'; }; f",
		"lint:ts": "tsc --noEmit && eslint --cache .",
		"lint:md": "markdownlint-cli2 '*.md'",
		"lint": "npm run lint:ts && npm run lint:md",
		"test:unit": "mocha dist/test/test.js",
		"test:parser": "mocha --reporter=progress dist/test/parserTests.js",
		"test": "npm run test:unit && npm run test:parser",
		"test:real": "node --enable-source-maps dist/test/real.js"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^2.4.2",
		"@bhsd/common": "^2.2.1",
		"@bhsd/nodejs": "^1.0.0",
		"@bhsd/test-util": "^1.2.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.11.0",
		"@typescript-eslint/parser": "^8.59.2",
		"diff2html-cli": "^5.2.15",
		"esbuild": "^0.28.0",
		"eslint": "^10.3.0",
		"eslint-plugin-es-x": "^9.6.0",
		"markdownlint-cli2": "^0.22.1",
		"mocha": "^11.7.5",
		"typescript": "^6.0.3"
	}
}
